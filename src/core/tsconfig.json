/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "outDir": "../../dist",
    "baseUrl": "./",
    "rootDir": "../",
    "paths": {
      "#core/*": ["./*"]
    },

    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": true,
    "experimentalDecorators": true,
    "generateCpuProfile": "profile.cpuprofile",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "preserveConstEnums": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false
  },
  "files": [
    "main.ts"
  ],
  "include": [
    "./**/*.d.ts",
    "./**/*.cts"
, "adapter/input/event/enum/EventNameEnum.ts", "preload.cts", "application/preload/interface/IPCEventsContracts.mts", "application/preload/interface/IPCEventsContracts.ts", "application/preload/service/IPCRendererService.ts"  ]
}
