{
  "name": "game-drawer",
  "author": "HenriBDev",
  "description": "An app developed to run your own fully customizable collection of games",
  "version": "0.0.0",
  "main": "dist/core/main.js",
  "imports": {
    "#core/*": "./dist/core/*"
  },
  "scripts": {
    "dev": "npm run dev:ui & npm run dev:core",
    "dist": "npm run transpile:core && npm run build:ui && electron-builder --win --x64",
    "build:ui": "ng build",
    "dev:ui": "ng serve",
    "test:ui": "ng test",
    "watch:ui": "ng build --watch --configuration development",
    "dev:core": "npm run transpile:core && electron .",
    "transpile:core": "tsc -p src/core/tsconfig.json",
    "transpile:ui": "tsc -p src/ui/tsconfig.app.json"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.15",
    "@angular/compiler": "^20.3.15",
    "@angular/core": "^20.3.15",
    "@angular/forms": "^20.3.15",
    "@angular/platform-browser": "^20.3.15",
    "@angular/platform-browser-dynamic": "^20.3.15",
    "@angular/router": "^20.3.15",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.13",
    "@angular/cli": "^20.3.13",
    "@angular/compiler-cli": "^20.3.15",
    "@types/jasmine": "~5.1.0",
    "electron": "^39.2.5",
    "electron-builder": "^26.0.12",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}